# s3-snowflakes-project
USE DATABASE HRMS;

CREATE OR REPLACE SCHEMA ETL;

CREATE OR REPLACE FILE FORMATE HRMS.ETL.CSV_ETL_FILEFORMATE
TYPE = CSV
FIELD_DELIMITER = ','
SKIP_HEDER = 0
NULL_IF = ('Null','NULL')
FIELD_OPTIONALLY_ENCLOSED_BY ='""'
TRIN_SPACE = TRUE
CONPRESSION = AUTO;


CREATE OR REPLACE STAGE HRMS.ETL.AWS_ETL_CSV_STAGE
STORAGE_INTEGRATION = AWS_S3_INT
URL = 's3//learn2cloud-snowflakes/loadingdata/csv/'
FILE_FORMATE = CSV_ETL_FILEFORMATE


CREATE OR REPLACE TABLE EMPLOYEES_COPY
(
EMPLOYEE_ID NUMBER(10),
FIRST_NAME VARCHAR(25),
LASTT_NAME VARCHAR(25),
EMAIL VARCHAR(20),
PHONE_NUMBER VARCHAR(20),
HIRE_DATE VARCHAR(20),
JOB_ID VARCHAR(20),
SALARY NUMBER(8,2),
COMMSSION_PCT DECIMAL(2,2),
NANAGER_ID NUMBER(6),
DEPARTMENT_ID NUMBER(5)

);

LIST @AWS_ETL_CSV_STAGE;

COPY INTO HRMS.ETL.EMPLOYEES_COPY FROM AWS_ETL_CSV_STAGE;

TRUNCATE TABLE EMPLOYEES_COPY;

COPY INTO EMPLOYEES_COPY FROM AWS_ETL_CSV_STAGE
FORCE = TRUE;
